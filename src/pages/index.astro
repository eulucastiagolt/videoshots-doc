<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>VideoShorts - YouTube Video Embed Library</title>
    <meta name="description" content="A lightweight JavaScript library for embedding YouTube videos with lazy loading support." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root {
        --primary: #7c3aed;
        --primary-light: #a78bfa;
        --primary-dark: #5b21b6;
        --bg: #0a0a0f;
        --bg-secondary: #12121a;
        --bg-tertiary: #1a1a25;
        --text: #f8f9fa;
        --text-muted: #9ca3af;
        --text-dim: #6b7280;
        --border: #1f2937;
        --border-light: #374151;
        --code-bg: #0d1117;
        --gradient-1: linear-gradient(135deg, #7c3aed 0%, #a78bfa 100%);
        --gradient-2: linear-gradient(135deg, #1a1a25 0%, #0a0a0f 100%);
      }
      
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      
      html {
        scroll-behavior: smooth;
      }
      
      body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        overflow-x: hidden;
      }
      
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }
      
      header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        background: rgba(10, 10, 15, 0.85);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
        z-index: 100;
      }
      
      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 0;
      }
      
      .logo {
        font-size: 1.5rem;
        font-weight: 800;
        background: var(--gradient-1);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-decoration: none;
      }
      
      .nav-links {
        display: flex;
        gap: 1.5rem;
        align-items: center;
      }
      
      .nav-links a {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.2s;
      }
      
      .nav-links a:hover {
        color: var(--text);
      }
      
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
        font-size: 0.9rem;
      }
      
      .btn-primary {
        background: var(--gradient-1);
        color: white;
        box-shadow: 0 4px 15px rgba(124, 58, 237, 0.3);
      }
      
      .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(124, 58, 237, 0.4);
      }
      
      .btn-secondary {
        background: var(--bg-tertiary);
        color: var(--text);
        border: 1px solid var(--border);
      }
      
      .btn-secondary:hover {
        border-color: var(--primary);
        background: var(--bg-secondary);
      }
      
      .btn-outline {
        background: transparent;
        color: var(--primary-light);
        border: 1px solid var(--primary);
      }
      
      .btn-outline:hover {
        background: var(--primary);
        color: white;
      }
      
      main {
        padding-top: 80px;
      }
      
      .hero {
        padding: 5rem 0 4rem;
        text-align: center;
        position: relative;
        overflow: hidden;
      }
      
      .hero::before {
        content: '';
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 800px;
        height: 600px;
        background: radial-gradient(circle, rgba(124, 58, 237, 0.15) 0%, transparent 70%);
        pointer-events: none;
      }
      
      .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        background: var(--bg-tertiary);
        border: 1px solid var(--border);
        border-radius: 2rem;
        font-size: 0.85rem;
        color: var(--text-muted);
        margin-bottom: 1.5rem;
      }
      
      .hero-badge span {
        color: var(--primary-light);
      }
      
      .hero h1 {
        font-size: 4rem;
        font-weight: 900;
        margin-bottom: 1.5rem;
        background: var(--gradient-1);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        line-height: 1.1;
      }
      
      .hero p {
        font-size: 1.25rem;
        color: var(--text-muted);
        max-width: 600px;
        margin: 0 auto 2.5rem;
        line-height: 1.7;
      }
      
      .hero-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 3rem;
      }
      
      .hero-buttons .btn {
        padding: 1rem 2rem;
        font-size: 1rem;
      }
      
      .code-preview {
        max-width: 700px;
        margin: 0 auto;
        text-align: left;
        background: var(--code-bg);
        border: 1px solid var(--border);
        border-radius: 0.75rem;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
      }
      
      .code-preview-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1rem;
        background: var(--bg-tertiary);
        border-bottom: 1px solid var(--border);
      }
      
      .code-preview-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
      }
      
      .code-preview-dot:nth-child(1) { background: #ff5f56; }
      .code-preview-dot:nth-child(2) { background: #ffbd2e; }
      .code-preview-dot:nth-child(3) { background: #27ca40; }
      
      .code-preview-title {
        margin-left: auto;
        font-size: 0.8rem;
        color: var(--text-dim);
      }
      
      .code-preview pre {
        padding: 1.25rem;
        overflow-x: auto;
        font-size: 0.85rem;
        line-height: 1.6;
      }
      
      .code-preview code {
        font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
        color: var(--text);
      }
      
      .code-keyword { color: #c792ea; }
      .code-string { color: #c3e88d; }
      .code-comment { color: #6b7280; }
      .code-function { color: #82aaff; }
      .code-property { color: #f78c6c; }
      
      section {
        padding: 5rem 0;
      }
      
      section h2 {
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 1rem;
        text-align: center;
      }
      
      section > .container > p {
        text-align: center;
        color: var(--text-muted);
        max-width: 600px;
        margin: 0 auto 3rem;
      }
      
      .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
      }
      
      .feature-card {
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 1rem;
        padding: 2rem;
        transition: all 0.3s;
      }
      
      .feature-card:hover {
        border-color: var(--primary);
        transform: translateY(-4px);
        box-shadow: 0 10px 30px rgba(124, 58, 237, 0.15);
      }
      
      .feature-icon {
        width: 50px;
        height: 50px;
        background: var(--gradient-1);
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.25rem;
        font-size: 1.5rem;
      }
      
      .feature-card h3 {
        font-size: 1.2rem;
        margin-bottom: 0.75rem;
        font-weight: 700;
      }
      
      .feature-card p {
        color: var(--text-muted);
        font-size: 0.95rem;
        line-height: 1.6;
      }
      
      .install-section {
        background: var(--bg-secondary);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
      }
      
      .install-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
        margin-top: 2rem;
      }
      
      .install-card {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 1rem;
        padding: 1.5rem;
      }
      
      .install-card h3 {
        font-size: 1rem;
        margin-bottom: 1rem;
        color: var(--text-muted);
      }
      
      .install-card pre {
        background: var(--code-bg);
        padding: 1rem;
        border-radius: 0.5rem;
        overflow-x: auto;
      }
      
      .install-card code {
        font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
        font-size: 0.9rem;
        color: var(--primary-light);
      }
      
      .urls-section {
        background: var(--bg-secondary);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
      }
      
      .urls-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
      }
      
      .url-card {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 0.75rem;
        padding: 1.25rem;
        text-align: center;
        transition: all 0.2s;
      }
      
      .url-card:hover {
        border-color: var(--primary);
      }
      
      .url-card h4 {
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
        color: var(--text);
      }
      
      .url-card code {
        font-size: 0.75rem;
        color: var(--primary-light);
        background: var(--code-bg);
        padding: 0.25rem 0.5rem;
        border-radius: 0.25rem;
      }
      
      .why-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        margin-top: 3rem;
      }
      
      .why-card {
        text-align: center;
        padding: 2rem;
      }
      
      .why-card h3 {
        font-size: 1.3rem;
        margin-bottom: 1rem;
        font-weight: 700;
      }
      
      .why-card p {
        color: var(--text-muted);
        font-size: 0.95rem;
      }
      
      .integration-section {
        background: var(--bg-secondary);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
      }
      
      .integration-card {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 1rem;
        padding: 2rem;
        display: flex;
        align-items: center;
        gap: 2rem;
        max-width: 600px;
        margin: 0 auto;
        transition: all 0.2s;
      }
      
      .integration-card:hover {
        border-color: var(--primary);
      }
      
      .integration-icon {
        width: 80px;
        height: 80px;
        background: var(--gradient-1);
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        flex-shrink: 0;
      }
      
      .integration-info h3 {
        font-size: 1.3rem;
        margin-bottom: 0.5rem;
      }
      
      .integration-info p {
        color: var(--text-muted);
        font-size: 0.95rem;
      }
      
      .browser-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        max-width: 800px;
        margin: 0 auto;
      }
      
      .browser-card {
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 0.75rem;
        padding: 1.5rem;
        text-align: center;
      }
      
      .browser-card svg {
        width: 32px;
        height: 32px;
        margin-bottom: 0.75rem;
        color: var(--text-muted);
      }
      
      .browser-card h4 {
        font-size: 0.9rem;
        margin-bottom: 0.25rem;
      }
      
      .browser-card p {
        font-size: 0.8rem;
        color: var(--text-dim);
      }
      
      .docs-section {
        background: var(--bg-secondary);
        border-top: 1px solid var(--border);
      }
      
      .docs-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
      }
      
      .docs-card {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 1rem;
        padding: 2rem;
        transition: all 0.2s;
      }
      
      .docs-card:hover {
        border-color: var(--primary);
        transform: translateY(-2px);
      }
      
      .docs-card h3 {
        font-size: 1.2rem;
        margin-bottom: 0.75rem;
        font-weight: 700;
      }
      
      .docs-card p {
        color: var(--text-muted);
        font-size: 0.95rem;
        margin-bottom: 1.25rem;
      }
      
      .docs-card a {
        color: var(--primary-light);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
      }
      
      .docs-card a:hover {
        text-decoration: underline;
      }
      
      .language-selector {
        position: relative;
      }
      
      .language-btn {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 0.5rem;
        color: var(--text);
        cursor: pointer;
        font-size: 0.9rem;
        transition: all 0.2s;
      }
      
      .language-btn:hover {
        border-color: var(--primary);
      }
      
      .language-menu {
        position: absolute;
        top: 100%;
        right: 0;
        margin-top: 0.5rem;
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 0.5rem;
        overflow: hidden;
        display: none;
        min-width: 160px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
      }
      
      .language-menu.active {
        display: block;
      }
      
      .language-menu a {
        display: block;
        padding: 0.75rem 1rem;
        color: var(--text);
        text-decoration: none;
        transition: background 0.2s;
      }
      
      .language-menu a:hover {
        background: var(--bg-tertiary);
      }
      
      footer {
        border-top: 1px solid var(--border);
        padding: 3rem 0;
        text-align: center;
      }
      
      .footer-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
      }
      
      .footer-links {
        display: flex;
        gap: 2rem;
      }
      
      .footer-links a {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.2s;
      }
      
      .footer-links a:hover {
        color: var(--text);
      }
      
      .footer-copy {
        color: var(--text-dim);
        font-size: 0.85rem;
      }
      
      @media (max-width: 1024px) {
        .features-grid {
          grid-template-columns: repeat(2, 1fr);
        }
        
        .why-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      
      @media (max-width: 768px) {
        .hero h1 {
          font-size: 2.5rem;
        }
        
        .hero p {
          font-size: 1rem;
        }
        
        .hero-buttons {
          flex-direction: column;
          align-items: center;
        }
        
        .hero-buttons .btn {
          width: 100%;
          max-width: 280px;
          justify-content: center;
        }
        
        .nav-links .btn {
          display: none;
        }
        
        section h2 {
          font-size: 2rem;
        }
        
        .features-grid,
        .install-grid,
        .why-grid,
        .docs-grid {
          grid-template-columns: 1fr;
        }
        
        .urls-grid {
          grid-template-columns: repeat(2, 1fr);
        }
        
        .browser-grid {
          grid-template-columns: repeat(2, 1fr);
        }
        
        .integration-card {
          flex-direction: column;
          text-align: center;
        }
        
        .footer-content {
          flex-direction: column;
          text-align: center;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <nav>
          <a href="/" class="logo" id="logo">VideoShorts</a>
          <div class="nav-links">
            <div class="language-selector">
              <button class="language-btn" id="langBtn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path fill-rule="evenodd" d="M8.516 3a.94.94 0 0 0-.941.94v1.15H2.94a.94.94 0 1 0 0 1.882h7.362a7.422 7.422 0 0 1-1.787 3.958 7.42 7.42 0 0 1-1.422-2.425.94.94 0 1 0-1.774.627 9.303 9.303 0 0 0 1.785 3.043 7.422 7.422 0 0 1-4.164 1.278.94.94 0 1 0 0 1.881 9.303 9.303 0 0 0 5.575-1.855 9.303 9.303 0 0 0 4.11 1.74l-.763 1.525a.968.968 0 0 0-.016.034l-1.385 2.77a.94.94 0 1 0 1.683.841l1.133-2.267h5.806l1.134 2.267a.94.94 0 0 0 1.683-.841l-1.385-2.769a.95.95 0 0 0-.018-.036l-3.476-6.951a.94.94 0 0 0-1.682 0l-1.82 3.639a7.423 7.423 0 0 1-3.593-1.256 9.303 9.303 0 0 0 2.27-5.203h1.894a.94.94 0 0 0 0-1.881H9.456V3.94A.94.94 0 0 0 8.516 3Zm6.426 11.794a1.068 1.068 0 0 1-.02.039l-.703 1.407h3.924l-1.962-3.924-1.24 2.478Z" clip-rule="evenodd"/>
                </svg>
                <span id="langLabel">English</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17 9.17a1 1 0 0 0-1.41 0L12 12.71 8.46 9.17a1 1 0 1 0-1.41 1.42l4.24 4.24a1.002 1.002 0 0 0 1.42 0L17 10.59a1.002 1.002 0 0 0 0-1.42Z"/>
                </svg>
              </button>
              <div class="language-menu" id="langMenu">
                {locales.map(locale => (
                  <a href={locale.path} data-lang={locale.code}>{locale.label}</a>
                ))}
              </div>
            </div>
            <a href="https://github.com/eulucastiagolt/videoshorts" target="_blank" rel="noopener">GitHub</a>
            <a href="/en/doc" class="btn btn-primary" id="docBtn">Documentation</a>
          </div>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="container">
          <div class="hero-badge">
            <span>v1.6.4</span> • <span id="heroBadge">Lightweight & Powerful</span>
          </div>
          <h1 id="heroTitle">VideoShorts</h1>
          <p id="heroIntro">A lightweight and powerful JavaScript library for embedding YouTube videos in your web applications, with native lazy loading support and a complete API for playback control.</p>
          <div class="hero-buttons">
            <a href="/en/doc" class="btn btn-primary" id="heroDocBtn">Get Started</a>
            <a href="https://github.com/eulucastiagolt/videoshorts" target="_blank" rel="noopener" class="btn btn-secondary" id="githubBtn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 .3a12 12 0 0 0-3.8 23.38c.6.12.83-.26.83-.57L9 21.07c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.08-.74.09-.73.09-.73 1.2.09 1.83 1.24 1.83 1.24 1.08 1.83 2.81 1.3 3.5 1 .1-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.28-1.55 3.29-1.23 3.29-1.23.64 1.66.24 2.88.12 3.18a4.65 4.65 0 0 1 1.23 3.22c0 4.61-2.8 5.63-5.48 5.92.42.36.81 1.1.81 2.22l-.01 3.29c0 .31.2.69.82.57A12 12 0 0 0 12 .3Z"/>
              </svg>
              <span id="githubBtnText">View on GitHub</span>
            </a>
          </div>
          
          <div class="code-preview">
            <div class="code-preview-header">
              <div class="code-preview-dot"></div>
              <div class="code-preview-dot"></div>
              <div class="code-preview-dot"></div>
              <span class="code-preview-title">index.html</span>
            </div>
            <pre><code><span class="code-comment">// Quick example</span>
<span class="code-keyword">const</span> player = <span class="code-keyword">new</span> <span class="code-function">VideoShorts</span>(<span class="code-string">'#videos'</span>, [
  <span class="code-string">'https://youtube.com/shorts/VIDEO_ID'</span>,
  <span class="code-string">'https://youtube.com/watch?v=VIDEO_ID'</span>
], &#123;
  <span class="code-property">lazy</span>: <span class="code-keyword">true</span>,
  <span class="code-property">muted</span>: <span class="code-keyword">true</span>,
  <span class="code-property">loop</span>: <span class="code-keyword">true</span>
&#125;);

player.<span class="code-function">init</span>();</code></pre>
          </div>
        </div>
      </section>

      <section class="features-section">
        <div class="container">
          <h2 id="featuresTitle">Features</h2>
          <p id="featuresDesc">Everything you need to embed and control YouTube videos</p>
          <div class="features-grid">
            <div class="feature-card">
              <div class="feature-icon">⚡</div>
              <h3 id="feature1Title">Lazy Loading</h3>
              <p id="feature1Desc">Loads videos only when visible using the Intersection Observer API for optimal performance.</p>
            </div>
            <div class="feature-card">
              <div class="feature-icon">🎮</div>
              <h3 id="feature2Title">Complete API</h3>
              <p id="feature2Desc">Full control over playback, volume, mute, seek, and all other video aspects.</p>
            </div>
            <div class="feature-card">
              <div class="feature-icon">📱</div>
              <h3 id="feature3Title">Responsive</h3>
              <p id="feature3Desc">Support for custom aspect ratios for Shorts (9/16) and regular videos (16/9).</p>
            </div>
            <div class="feature-card">
              <div class="feature-icon">📦</div>
              <h3 id="feature4Title">Zero Dependencies</h3>
              <p id="feature4Desc">Standalone library with no external dependencies. Lightweight and fast.</p>
            </div>
            <div class="feature-card">
              <div class="feature-icon">🔌</div>
              <h3 id="feature5Title">Library Friendly</h3>
              <p id="feature5Desc">Compatible with SwiperJS, Slick, and other carousel/slider libraries.</p>
            </div>
            <div class="feature-card">
              <div class="feature-icon">🖼️</div>
              <h3 id="feature6Title">Thumbnail Support</h3>
              <p id="feature6Desc">Show video thumbnails with smooth transitions before playback starts.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="install-section">
        <div class="container">
          <h2 id="installTitle">Installation</h2>
          <p id="installDesc">Get started in seconds with npm or CDN</p>
          <div class="install-grid">
            <div class="install-card">
              <h3 id="installNpmTitle">Install via npm</h3>
              <pre><code>npm install videoshots</code></pre>
            </div>
            <div class="install-card">
              <h3 id="installCdnTitle">Or use CDN</h3>
              <pre><code>&lt;script src="https://cdn.jsdelivr.net/gh/eulucastiagolt/videoshorts@1.6.4/dist/videoshots.min.js"&gt;&lt;/script&gt;</code></pre>
            </div>
          </div>
        </div>
      </section>

      <section class="urls-section">
        <div class="container">
          <h2 id="urlsTitle">Supported URL Formats</h2>
          <p id="urlsDesc">Works with all YouTube URL formats</p>
          <div class="urls-grid">
            <div class="url-card">
              <h4 id="urlWatchTitle">YouTube Watch</h4>
              <code>youtube.com/watch?v=</code>
            </div>
            <div class="url-card">
              <h4 id="urlShortsTitle">YouTube Shorts</h4>
              <code>youtube.com/shorts/</code>
            </div>
            <div class="url-card">
              <h4 id="urlEmbedTitle">YouTube Embed</h4>
              <code>youtube.com/embed/</code>
            </div>
            <div class="url-card">
              <h4 id="urlBeTitle">youtu.be</h4>
              <code>youtu.be/</code>
            </div>
          </div>
        </div>
      </section>

      <section>
        <div class="container">
          <h2 id="whyTitle">Why VideoShorts?</h2>
          <p id="whyDesc">The best choice for embedding YouTube videos</p>
          <div class="why-grid">
            <div class="why-card">
              <h3 id="why1Title">Performance</h3>
              <p id="why1Desc">Automatic lazy loading reduces initial page load time and improves Core Web Vitals.</p>
            </div>
            <div class="why-card">
              <h3 id="why2Title">Flexibility</h3>
              <p id="why2Desc">Support for multiple YouTube URL formats and complete customization options.</p>
            </div>
            <div class="why-card">
              <h3 id="why3Title">Full Control</h3>
              <p id="why3Desc">Intuitive API to control all aspects of playback with event callbacks.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="integration-section">
        <div class="container">
          <h2 id="integrationTitle">Integration</h2>
          <p id="integrationDesc">Works seamlessly with popular libraries</p>
          <div class="integration-card">
            <div class="integration-icon">🌀</div>
            <div class="integration-info">
              <h3 id="swiperTitle">SwiperJS</h3>
              <p id="swiperDesc">Full support for loop mode and all Swiper features</p>
            </div>
          </div>
        </div>
      </section>

      <section>
        <div class="container">
          <h2 id="browserTitle">Browser Support</h2>
          <p id="browserDesc">Supports all modern browsers</p>
          <div class="browser-grid">
            <div class="browser-card">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
              <h4>Chrome</h4>
              <p id="chromeVersion">51+</p>
            </div>
            <div class="browser-card">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
              <h4>Firefox</h4>
              <p id="firefoxVersion">55+</p>
            </div>
            <div class="browser-card">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
              <h4>Safari</h4>
              <p id="safariVersion">12.1+</p>
            </div>
            <div class="browser-card">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
              <h4>Edge</h4>
              <p id="edgeVersion">15+</p>
            </div>
          </div>
        </div>
      </section>

      <section class="docs-section">
        <div class="container">
          <h2 id="docsTitle">Documentation</h2>
          <p id="docsDesc">Explore our comprehensive documentation</p>
          <div class="docs-grid">
            <div class="docs-card">
              <h3 id="docsCardTitle">Documentation</h3>
              <p id="docsCardDesc">Explore our comprehensive documentation</p>
              <a href="/en/doc" id="docsLink">Read the Docs →</a>
            </div>
            <div class="docs-card">
              <h3 id="apiCardTitle">API Reference</h3>
              <p id="apiCardDesc">Full API methods and events reference</p>
              <a href="/en/doc/api/methods" id="apiLink">View API →</a>
            </div>
            <div class="docs-card">
              <h3 id="examplesCardTitle">Examples</h3>
              <p id="examplesCardDesc">Practical examples and use cases</p>
              <a href="/en/doc/examples/basic" id="examplesLink">See Examples →</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <div class="container">
        <div class="footer-content">
          <div class="footer-links">
            <a href="/en/doc">Documentation</a>
            <a href="https://github.com/eulucastiagolt/videoshorts" target="_blank" rel="noopener">GitHub</a>
            <a href="https://www.npmjs.com/package/videoshots" target="_blank" rel="noopener">npm</a>
          </div>
          <p class="footer-copy">© 2024 VideoShorts. Released under the MIT License.</p>
        </div>
      </div>
    </footer>

    <script define:vars={{ translations, locales }}>
      const userLang = navigator.language.toLowerCase();
      const defaultLang = 'en';
      
      let currentLang = defaultLang;
      
      for (const locale of locales) {
        if (userLang.startsWith(locale.code) || (locale.code === 'pt-br' && userLang.startsWith('pt'))) {
          currentLang = locale.code;
          break;
        }
      }
      
      const t = translations[currentLang] || translations[defaultLang];
      
      document.documentElement.lang = currentLang === 'zh' ? 'zh-CN' : (currentLang === 'pt-br' ? 'pt-BR' : 'en');
      document.title = `${t.title} - YouTube Video Embed Library`;
      document.querySelector('meta[name="description"]').content = t.description;
      
      document.getElementById('heroTitle').textContent = t.title;
      document.getElementById('heroIntro').textContent = t.intro;
      document.getElementById('heroDocBtn').textContent = t.getStarted;
      document.getElementById('docBtn').textContent = t.getStarted;
      document.getElementById('githubBtnText').textContent = t.viewOnGithub;
      
      document.getElementById('featuresTitle').textContent = t.features;
      document.getElementById('feature1Title').textContent = t.lazyLoading;
      document.getElementById('feature1Desc').textContent = t.lazyLoadingDesc;
      document.getElementById('feature2Title').textContent = t.completeApi;
      document.getElementById('feature2Desc').textContent = t.completeApiDesc;
      document.getElementById('feature3Title').textContent = t.responsive;
      document.getElementById('feature3Desc').textContent = t.responsiveDesc;
      document.getElementById('feature4Title').textContent = t.zeroDeps;
      document.getElementById('feature4Desc').textContent = t.zeroDepsDesc;
      document.getElementById('feature5Title').textContent = t.libraryFriendly;
      document.getElementById('feature5Desc').textContent = t.libraryFriendlyDesc;
      document.getElementById('feature6Title').textContent = t.thumbnail;
      document.getElementById('feature6Desc').textContent = t.thumbnailDesc;
      
      document.getElementById('installTitle').textContent = t.installation;
      document.getElementById('installNpmTitle').textContent = t.installNpm;
      document.getElementById('installCdnTitle').textContent = t.installCdn;
      
      document.getElementById('urlsTitle').textContent = t.supportedUrls;
      document.getElementById('urlsDesc').textContent = t.supportedUrlsDesc;
      document.getElementById('urlWatchTitle').textContent = t.urlWatch;
      document.getElementById('urlShortsTitle').textContent = t.urlShorts;
      document.getElementById('urlEmbedTitle').textContent = t.urlEmbed;
      document.getElementById('urlBeTitle').textContent = t.urlBe;
      
      document.getElementById('whyTitle').textContent = t.whyVideoShorts;
      document.getElementById('why1Title').textContent = t.performance;
      document.getElementById('why1Desc').textContent = t.performanceDesc;
      document.getElementById('why2Title').textContent = t.flexibility;
      document.getElementById('why2Desc').textContent = t.flexibilityDesc;
      document.getElementById('why3Title').textContent = t.fullControl;
      document.getElementById('why3Desc').textContent = t.fullControlDesc;
      
      document.getElementById('integrationTitle').textContent = t.integration;
      document.getElementById('integrationDesc').textContent = t.integrationDesc;
      document.getElementById('swiperTitle').textContent = t.swiperTitle;
      document.getElementById('swiperDesc').textContent = t.swiperDesc;
      
      document.getElementById('browserTitle').textContent = t.browserSupport;
      document.getElementById('browserDesc').textContent = t.browserSupportDesc;
      document.getElementById('chromeVersion').textContent = t.chrome;
      document.getElementById('firefoxVersion').textContent = t.firefox;
      document.getElementById('safariVersion').textContent = t.safari;
      document.getElementById('edgeVersion').textContent = t.edge;
      
      document.getElementById('docsTitle').textContent = t.docs;
      document.getElementById('docsDesc').textContent = t.docsDesc;
      document.getElementById('docsCardTitle').textContent = t.docs;
      document.getElementById('docsCardDesc').textContent = t.docsDesc;
      document.getElementById('docsLink').textContent = t.docsLink + ' →';
      document.getElementById('apiCardTitle').textContent = t.api;
      document.getElementById('apiCardDesc').textContent = t.apiDesc;
      document.getElementById('apiLink').textContent = t.apiLink + ' →';
      document.getElementById('examplesCardTitle').textContent = t.examples;
      document.getElementById('examplesCardDesc').textContent = t.examplesDesc;
      document.getElementById('examplesLink').textContent = t.examplesLink + ' →';
      
      document.getElementById('langLabel').textContent = locales.find(l => l.code === currentLang)?.label || 'English';
      
      const docPath = '/' + currentLang + '/doc';
      document.getElementById('docBtn').href = docPath;
      document.getElementById('heroDocBtn').href = docPath;
      document.getElementById('docsLink').href = docPath;
      document.getElementById('apiLink').href = '/' + currentLang + '/doc/api/methods';
      document.getElementById('examplesLink').href = '/' + currentLang + '/doc/examples/basic';
      
      document.getElementById('langBtn').addEventListener('click', () => {
        document.getElementById('langMenu').classList.toggle('active');
      });
      
      document.addEventListener('click', (e) => {
        const target = e.target;
        if (!target?.closest('.language-selector')) {
          document.getElementById('langMenu')?.classList.remove('active');
        }
      });
    </script>
  </body>
</html>